<section
  id="panorama"
  class="snap-section relative flex items-center overflow-hidden bg-dark-bg p-6 py-10 lg:py-0 lg:px-0"
>
  <!-- Parallax background -->

  <div class="absolute inset-0 bg-dark-bg/70" aria-hidden="true"></div>

  <div class="relative z-10 w-full">
    <div class="mx-auto w-full max-w-6xl lg:ml-[clamp(4rem,12vw,10rem)]">
      <!-- Section label -->
      <p class="text-xs font-semibold uppercase tracking-[0.5em] text-accent">
        Co zawiera obóz
      </p>
      <h2
        class="mt-3 font-heading text-[clamp(2rem,6vw,4.5rem)] font-800 uppercase leading-[0.9] text-dark-text"
      >
        4 dni, które<br />zapamiętasz
      </h2>
    </div>

    <!-- Cards grid — offset from spine -->
    <div class="mx-auto mt-12 w-full max-w-6xl lg:ml-[clamp(4rem,12vw,10rem)]">
      <div class="grid gap-px sm:grid-cols-2 lg:grid-cols-4">
        <article
          class="group relative border-l-2 border-accent/30 bg-dark-bg/60 p-8 backdrop-blur-md transition-colors duration-300 hover:bg-dark-bg/80"
        >
          <span
            class="font-heading text-5xl font-bold text-accent/20 transition-colors duration-300 group-hover:text-accent/40"
            >01</span
          >
          <h3
            class="mt-4 font-heading text-2xl font-bold uppercase text-dark-text"
          >
            Treningi
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-muted">
            Codzienne zajęcia z elementami boksu, kick-boxingu i MMA pod okiem
            Piotra Strusa.
          </p>
        </article>

        <article
          class="group relative border-l-2 border-accent/30 bg-dark-bg/60 p-8 backdrop-blur-md transition-colors duration-300 hover:bg-dark-bg/80"
        >
          <span
            class="font-heading text-5xl font-bold text-accent/20 transition-colors duration-300 group-hover:text-accent/40"
            >02</span
          >
          <h3
            class="mt-4 font-heading text-2xl font-bold uppercase text-dark-text"
          >
            Góry
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-muted">
            Codzienne wyjścia w Tatry — szlaki dopasowane do kondycji grupy.
          </p>
        </article>

        <article
          class="group relative border-l-2 border-accent/30 bg-dark-bg/60 p-8 backdrop-blur-md transition-colors duration-300 hover:bg-dark-bg/80"
        >
          <span
            class="font-heading text-5xl font-bold text-accent/20 transition-colors duration-300 group-hover:text-accent/40"
            >03</span
          >
          <h3
            class="mt-4 font-heading text-2xl font-bold uppercase text-dark-text"
          >
            Zakwaterowanie
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-muted">
            Willa Basieńka w centrum Zakopanego. Pokoje 2–3 osobowe z
            możliwością wyboru współlokatora.
          </p>
        </article>

        <article
          class="group relative border-l-2 border-accent/30 bg-dark-bg/60 p-8 backdrop-blur-md transition-colors duration-300 hover:bg-dark-bg/80"
        >
          <span
            class="font-heading text-5xl font-bold text-accent/20 transition-colors duration-300 group-hover:text-accent/40"
            >04</span
          >
          <h3
            class="mt-4 font-heading text-2xl font-bold uppercase text-dark-text"
          >
            Wyżywienie
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-dark-muted">
            Pełne wyżywienie — 3 posiłki dziennie przez cały pobyt. Od kolacji
            22.04 do śniadania 26.04.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>
