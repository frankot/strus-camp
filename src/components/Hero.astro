<section
  id="hero"
  class="snap-section min-h-svh relative flex flex-col justify-center bg-dark-bg px-6 lg:px-0"
>
  <div
    class="absolute inset-0 bg-[url('/hero-bg-mob.webp')] md:bg-[url('/bg.webp')] bg-cover bg-center"
    aria-hidden="true"
  >
  </div>
  <div class="absolute inset-0 bg-black/45 lg:bg-black/35" aria-hidden="true"></div>

  <!-- <div class="absolute h-[400px] right-32  aspect-video "><img src="/bg.webp" alt=""></div> -->
  <div
    class="relative z-10 mx-auto w-full max-w-6xl lg:ml-[clamp(4rem,12vw,10rem)]"
  >
    <!-- Overline -->
    <p
      class="mb-4 text-sm w-fit px-3 py-1 rounded font-semibold uppercase tracking-[0.5em] text-dark-text"
    >
      Piotr Strus zaprasza
    </p>

    <h1
      class="font-heading text-[clamp(3.5rem,12vw,9rem)] font-900 uppercase leading-[0.85] tracking-tight text-dark-text"
    >
      <span class="text-accent">Sport</span><br />Camp
    </h1>

    <div class="mt-6 flex items-center gap-4">
      <span class="inline-block h-px w-6 lg:w-12 bg-accent" aria-hidden="true"></span>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-dark">
       <span class="text-accent">Tatry</span>  &middot; 23–26 Kwietnia 2026
      </p>
    </div>

    <div class="mt-12 flex flex-wrap gap-4">
      <a
        href="#contact"
        class="cursor-pointer bg-accent px-8 py-4 text-sm font-bold uppercase tracking-wider text-dark-bg transition-colors duration-200 hover:bg-accent/90"
      >
        Zapisz się
      </a>
      <a
        href="#panorama"
        class="cursor-pointer border-2 border-accent px-8 py-4 text-sm font-medium uppercase tracking-wider text-dark-text transition-all duration-200 hover:border-accent hover:text-accent"
      >
        Szczegóły
      </a>
    </div>

    <!-- Quick facts — horizontal strip -->
    <div class="mt-20 flex flex-wrap gap-12">
      <div>
        <p class="font-heading text-3xl font-bold text-dark-text">23–26.04</p>
        <p
          class="mt-1 text-xs font-semibold uppercase tracking-[0.3em] text-dark-muted"
        >
          Termin
        </p>
      </div>
      <div>
        <p class="font-heading text-3xl font-bold text-dark-text">Zakopane</p>
        <p
          class="mt-1 text-xs font-semibold uppercase tracking-[0.3em] text-dark-muted"
        >
          Lokalizacja
        </p>
      </div>
      <div class="relative">
        <div class="absolute text-dark-text font-extrabold -right-14 -top-2 px-2 py-1 border-2 border-accent rounded -rotate-12 text-xs">
          PROMO
        </div>
        <p class="font-heading text-3xl font-bold text-accent">1399 zł</p>
        <p
          class="mt-1 text-xs font-semibold uppercase tracking-[0.3em] text-dark-muted"
        >
          Od / os.
        </p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"
    aria-hidden="true"
  >
    <svg
      width="20"
      height="30"
      viewBox="0 0 20 30"
      fill="none"
      class="text-dark-muted"
    >
      <rect
        x="1"
        y="1"
        width="18"
        height="28"
        rx="9"
        stroke="currentColor"
        stroke-width="1.5"></rect>
      <circle cx="10" cy="10" r="2" fill="currentColor" class="animate-pulse"
      ></circle>
    </svg>
  </div>
</section>
